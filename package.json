{
  "name": "larva-starter",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "bun run --cwd packages/larvadb build && next build && pagefind --site .next/server/app --output-path public/_pagefind",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@larva-db/core": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "@vercel/blob": "^2.6.1",
    "next": "16.2.10",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.14",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "zod": "4.1.11"
  }
}