  {
   "id": "text-959760866",
   "angle": 0,
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "seed": 1058983683,
   "version": 1,
   "versionNonce": 749740909,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1783000000000,
   "link": null,
   "locked": false,
   "type": "text",
   "x": 662,
   "y": 1389,
   "width": 559,
   "height": 219,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "roundness": null,
   "text": "BEGIN;\nCREATE TABLE \"customers\" (\n  \"id\" text PRIMARY KEY,      -- text      \u2192 text\n  \"views\" bigint,             -- integer   \u2192 bigint\n  \"stars\" double precision,   -- real      \u2192 double precision\n  \"createdAt\" timestamptz     -- timestamp \u2192 timestamptz (ISO parses)\n);\nCOPY \"customers\" (\u2026) FROM stdin;   -- bulk data, pg's fastest path\n01K\u2026  Ada  ada@example.com  2026-06-01T00:00:00Z\n\\.\nALTER TABLE \"orders\" ADD CONSTRAINT \"orders_customerId_fkey\"\n  FOREIGN KEY (\"customerId\") REFERENCES \"customers\" (\"id\");\nCOMMIT;",
   "fontSize": 13.5,
   "fontFamily": 3,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "BEGIN;\nCREATE TABLE \"customers\" (\n  \"id\" text PRIMARY KEY,      -- text      \u2192 text\n  \"views\" bigint,             -- integer   \u2192 bigint\n  \"stars\" double precision,   -- real      \u2192 double precision\n  \"createdAt\" timestamptz     -- timestamp \u2192 timestamptz (ISO parses)\n);\nCOPY \"customers\" (\u2026) FROM stdin;   -- bulk data, pg's fastest path\n01K\u2026  Ada  ada@example.com  2026-06-01T00:00:00Z\n\\.\nALTER TABLE \"orders\" ADD CONSTRAINT \"orders_customerId_fkey\"\n  FOREIGN KEY (\"customerId\") REFERENCES \"customers\" (\"id\");\nCOMMIT;",
   "autoResize": true,
   "lineHeight": 1.25
  },
  {
   "id": "text-238282337",
   "angle": 0,
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "seed": 1084285174,
   "version": 1,
   "versionNonce": 635680642,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1783000000000,
   "link": null,
   "locked": false,
   "type": "text",
   "x": 662,
   "y": 1675,
   "width": 507,
   "height": 32,
   "strokeColor": "#495057",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "roundness": null,
   "text": "foreign keys come AFTER the data (like pg_dump) \u2192 load order never matters.\nyour .references() declarations became real, enforced constraints.",
   "fontSize": 13,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "foreign keys come AFTER the data (like pg_dump) \u2192 load order never matters.\nyour .references() declarations became real, enforced constraints.",
   "autoResize": true,
   "lineHeight": 1.25
  },
