   "strokeColor": "#495057",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "roundness": null,
   "text": "\u2192 db.asOf(tenMinutesAgo) reads the past (free time travel)\n\u2192 db.rollbackTo(v) is the undo button \u2014 itself just a new commit\n(vacuum reclaims outside 7 days / 50 versions)",
   "fontSize": 13,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\u2192 db.asOf(tenMinutesAgo) reads the past (free time travel)\n\u2192 db.rollbackTo(v) is the undo button \u2014 itself just a new commit\n(vacuum reclaims outside 7 days / 50 versions)",
   "autoResize": true,
   "lineHeight": 1.25
  },
