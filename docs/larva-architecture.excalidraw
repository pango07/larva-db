   "type": "text",
   "x": 124,
   "y": 2423,
   "width": 1092,
   "height": 18,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "roundness": null,
   "text": "Commit payloads are deltas \u2192 write cost stops scaling with database size. Same jittered backoff, same loud ConflictError \u2014 zero lost updates, verified",
   "fontSize": 14,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "Commit payloads are deltas \u2192 write cost stops scaling with database size. Same jittered backoff, same loud ConflictError \u2014 zero lost updates, verified",
   "autoResize": true,
   "lineHeight": 1.25
  },
