   "verticalAlign": "top",
   "containerId": null,
   "originalText": "The guarantee:  v7 \u2192 v8 \u2192 v9 \u2014 both writes landed. Zero lost updates, ever.",
   "autoResize": true,
   "lineHeight": 1.25
  },
  {
   "id": "text-501318446",
   "angle": 0,
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "seed": 1003571995,
   "version": 1,
   "versionNonce": 1604754261,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1783000000000,
   "link": null,
   "locked": false,
   "type": "text",
   "x": 984,
   "y": 1086,
   "width": 582,
   "height": 18,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "roundness": null,
   "text": "If 15 attempts fail \u2192 ConflictError, loudly. Larva never loses a write silently.",
   "fontSize": 14,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "If 15 attempts fail \u2192 ConflictError, loudly. Larva never loses a write silently.",
   "autoResize": true,
   "lineHeight": 1.25
  },
  {
