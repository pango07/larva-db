   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "roundness": null,
   "text": "\u2022  no  (disjoint tables/chunks)   \u2192  REBASE: re-point the same staged chunks at v8 \u2014 cheap",
   "fontSize": 14,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
