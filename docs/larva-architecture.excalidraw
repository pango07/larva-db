  {
   "id": "text-962478152",
   "angle": 0,
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "seed": 109567806,
   "version": 1,
   "versionNonce": 1184864288,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1783000000000,
   "link": null,
   "locked": false,
   "type": "text",
   "x": 984,
   "y": 1054,
   "width": 624,
   "height": 20,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "roundness": null,
   "text": "The guarantee:  v7 \u2192 v8 \u2192 v9 \u2014 both writes landed. Zero lost updates, ever.",
   "fontSize": 16,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "The guarantee:  v7 \u2192 v8 \u2192 v9 \u2014 both writes landed. Zero lost updates, ever.",
   "autoResize": true,
   "lineHeight": 1.25
  },
  {
   "id": "text-660988965",
   "angle": 0,
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "seed": 227672540,
   "version": 1,
   "versionNonce": 830122714,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1783000000000,
   "link": null,
   "locked": false,
   "type": "text",
   "x": 984,
   "y": 1086,
   "width": 582,
   "height": 18,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "roundness": null,
   "text": "If 15 attempts fail \u2192 ConflictError, loudly. Larva never loses a write silently.",
   "fontSize": 14,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "If 15 attempts fail \u2192 ConflictError, loudly. Larva never loses a write silently.",
   "autoResize": true,
   "lineHeight": 1.25
  },
  {
   "id": "text-993176949",
   "angle": 0,
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "seed": 1380695827,
   "version": 1,
   "versionNonce": 1208646028,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1783000000000,
   "link": null,
   "locked": false,
   "type": "text",
   "x": 984,
   "y": 1112,
   "width": 662,
   "height": 18,
   "strokeColor": "#495057",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "roundness": null,
   "text": "Writers inside ONE process never even race \u2014 group commit coalesces them into a single CAS.",
   "fontSize": 14,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "Writers inside ONE process never even race \u2014 group commit coalesces them into a single CAS.",
   "autoResize": true,
   "lineHeight": 1.25
  },
