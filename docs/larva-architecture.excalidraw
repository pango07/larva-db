   }
  },
  {
   "id": "text-819191151",
   "angle": 0,
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "seed": 1532932692,
   "version": 1,
   "versionNonce": 136281829,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1783000000000,
