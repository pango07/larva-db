   "type": "text",
   "x": 124,
   "y": 2337,
   "width": 803,
   "height": 19,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "roundness": null,
   "text": "B reads A's tiny entry (not the whole manifest), rebases its already-staged chunks, and takes slot 13 \u2014",
   "fontSize": 15,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "B reads A's tiny entry (not the whole manifest), rebases its already-staged chunks, and takes slot 13 \u2014",
   "autoResize": true,
   "lineHeight": 1.25
  },
  {
   "id": "text-196994709",
   "angle": 0,
   "strokeWidth": 2,
   "strokeStyle": "solid",
   "roughness": 1,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "seed": 829743330,
   "version": 1,
   "versionNonce": 635516217,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1783000000000,
   "link": null,
   "locked": false,
   "type": "text",
   "x": 124,
   "y": 2363,
   "width": 803,
   "height": 19,
   "strokeColor": "#1e1e1e",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "roundness": null,
   "text": "losing a race costs one small read + one retry. Same re-execute-on-overlap when rows genuinely collide.",
   "fontSize": 15,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "losing a race costs one small read + one retry. Same re-execute-on-overlap when rows genuinely collide.",
   "autoResize": true,
   "lineHeight": 1.25
  },
  {
